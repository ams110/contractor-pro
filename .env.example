# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Phase 2: Paddle Billing ─────────────────────────────────────────────────
# Sandbox:  https://sandbox-vendors.paddle.com → Developer Tools → Authentication
# Live:     https://vendors.paddle.com → Developer Tools → Authentication
# VITE_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxx
# VITE_PADDLE_ENVIRONMENT=sandbox         # or "production"
# PADDLE_API_KEY=your_paddle_api_key      # server-side only (Edge Function secret)
# PADDLE_WEBHOOK_SECRET=your_webhook_secret

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL used for magic link redirects and Paddle webhooks
# VITE_APP_URL=https://your-app.netlify.app
