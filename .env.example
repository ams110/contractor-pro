# ─── Supabase ────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Paddle Billing ───────────────────────────────────────────────────────────
# Sandbox:  https://sandbox-vendors.paddle.com → Developer Tools → Authentication
# Live:     https://vendors.paddle.com         → Developer Tools → Authentication

# Client-side token (safe to expose — starts with "test_" in sandbox)
VITE_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxx

# Environment: "sandbox" during development, "production" for live
VITE_PADDLE_ENVIRONMENT=sandbox

# Price IDs — found in Paddle Dashboard → Catalog → Prices
# Create one price per plan (recurring, monthly, ILS currency)
VITE_PADDLE_PRICE_STARTER=pri_xxxxxxxxxxxxxxxxxxxxxx
VITE_PADDLE_PRICE_PRO=pri_xxxxxxxxxxxxxxxxxxxxxx
VITE_PADDLE_PRICE_BUSINESS=pri_xxxxxxxxxxxxxxxxxxxxxx

# ─── Payment provider switch ─────────────────────────────────────────────────
# 'paddle' (افتراضي) أو 'icount' (بوّابة إسرائيلية: فيزا/ماستركارد + הוראת קבע)
VITE_PAYMENT_PROVIDER=paddle

# ─── iCount (بوّابة دفع إسرائيلية) ─────────────────────────────────────────────
# فعّلها بـ VITE_PAYMENT_PROVIDER=icount + VITE_ICOUNT_ENABLED=true
# (لا تضع أسرار iCount هنا — فقط الراية. الأسرار في Supabase secrets أدناه)
VITE_ICOUNT_ENABLED=false

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Public key — safe to put here (used on the client)
VITE_VAPID_PUBLIC_KEY=BBWTNkHM3Nz5Rc5sDSLDp0YMXwI-QXqP3VmdDO4hkrCuWuLE3mX5Zt7ZfmhimxwE5NZsbbGMklqpyLB7TO99awI

# ─── Supabase Edge Function secrets (set via Supabase CLI, NOT in .env) ───────
# Run:  supabase secrets set PADDLE_WEBHOOK_SECRET=...
#
# PADDLE_WEBHOOK_SECRET      — from Paddle Dashboard → Notifications → Webhook secret
# PADDLE_API_KEY             — from Paddle Dashboard → Developer Tools → API keys
# PADDLE_PRICE_ID_STARTER    — same as VITE_PADDLE_PRICE_STARTER (server-side copy)
# PADDLE_PRICE_ID_PRO        — same as VITE_PADDLE_PRICE_PRO
# PADDLE_PRICE_ID_BUSINESS   — same as VITE_PADDLE_PRICE_BUSINESS
# VAPID_PUBLIC_KEY           — same as VITE_VAPID_PUBLIC_KEY (server-side copy)
# VAPID_PRIVATE_KEY          — (لا تضعه هنا أبداً — استخدم Supabase secrets فقط)
#
# ─── iCount secrets (server-side only) ───────────────────────────────────────
# ICOUNT_CID                 — معرّف الشركة في iCount (companyId)
# ICOUNT_USER                — اسم مستخدم API
# ICOUNT_PASS                — كلمة مرور API
# ICOUNT_PRICE_STARTER       — سعر شهري بالشيقل (افتراضي 129)
# ICOUNT_PRICE_PRO           — سعر شهري بالشيقل (افتراضي 249)
# ICOUNT_PRICE_BUSINESS      — سعر شهري بالشيقل (افتراضي 499)
# ICOUNT_WEBHOOK_SECRET      — سرّ عشوائي تولّده أنت (يُمرَّر في رابط الـIPN للتحقّق)
# ICOUNT_API_BASE            — (اختياري) افتراضي https://api.icount.co.il/api/v3.php
# APP_URL                    — رابط التطبيق العام (لروابط النجاح/الفشل)

# ─── App ─────────────────────────────────────────────────────────────────────
# Public URL — used for magic link redirects and Paddle webhook registration
VITE_APP_URL=https://your-app.netlify.app
